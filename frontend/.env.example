# ============================================================
# Frontend Environment Variables
# Copy to .env.local and fill in values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# ---- API ----
NEXT_PUBLIC_API_URL=http://localhost:7381

# ---- Supabase (browser-safe keys only) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Web Push ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ---- Agent Branding ----
NEXT_PUBLIC_AGENT_NAME=Your Name
NEXT_PUBLIC_AGENT_TITLE=Real Estate Agent
NEXT_PUBLIC_AGENT_PHONE=(555) 000-0000
NEXT_PUBLIC_AGENT_EMAIL=you@yourdomain.com
NEXT_PUBLIC_SITE_NAME=Kaptivating Homes
