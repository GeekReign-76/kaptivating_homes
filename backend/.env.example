# ============================================================
# Backend Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=7381
FRONTEND_URL=http://localhost:4712

# ---- Supabase ----
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Redis (BullMQ queues + caching) ----
# Local: redis://localhost:6379
# Upstash: use REDIS_URL from Upstash console (TLS URL)
REDIS_URL=redis://localhost:6379

# ---- VAPID Keys for Web Push ----
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@yourdomain.com

# ---- MLS / Bridge Interactive ----
# SC market credentials
BRIDGE_SC_DATASET_ID=your-sc-dataset-id
BRIDGE_SC_CLIENT_ID=your-sc-client-id
BRIDGE_SC_CLIENT_SECRET=your-sc-client-secret

# Add GA / FL equivalents when expanding:
# BRIDGE_GA_DATASET_ID=...
# BRIDGE_GA_CLIENT_ID=...
# BRIDGE_GA_CLIENT_SECRET=...

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@yourdomain.com
SENDGRID_FROM_NAME=Your Name

# ---- Agent Identity ----
AGENT_NAME=Your Name
AGENT_EMAIL=you@yourdomain.com

AGENT_USER_ID=your-supabase-user-uuid-here
